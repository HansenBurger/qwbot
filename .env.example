# 企业微信群机器人 webhook。不要提交真实 key。
WECOM_WEBHOOK_URL_PROD=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=replace-with-prod-key
WECOM_WEBHOOK_URL_TEST=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=replace-with-test-key
WECOM_WEBHOOK_TARGET=test

# 机器人消息配置
BOT_TITLE=贷款核算测试日报提醒
SYSTEM_DATE_FORMAT=%Y-%m-%d
TIMEZONE=Asia/Shanghai

# 定时任务默认在每个工作日 09:00 和 18:00 发送，可在维护页面调整发送时间。

# 文档数据源。
# 优先填写已发布/可访问的 JSON 或 CSV URL；为空时读取 data/sample_status.json。
PROGRESS_SOURCE_URL=
BATCH_PLAN_SOURCE_URL=
PROGRESS_DOC_URL=https://doc.weixin.qq.com/sheet/your-progress-doc
BATCH_REGISTER_DOC_URL=https://doc.weixin.qq.com/sheet/your-batch-register-doc
CASE_ASSIGNMENT_DOC_URL=https://doc.weixin.qq.com/sheet/your-case-assignment-doc
AGENDA_DOC_URL=https://doc.weixin.qq.com/sheet/your-agenda-doc
FRONTEND_URL=http://127.0.0.1:5000
LOCAL_STATUS_FILE=data/sample_status.json
QWBOT_DB_PATH=data/qwbot.sqlite3

# 如果企业微信在线文档需要通过应用凭证访问，可在此补充。
WECOM_CORP_ID=
WECOM_CORP_SECRET=
WECOM_DOC_ID=
BATCH_REGISTER_DOC_ID=
BATCH_SMALL_ENV_SHEET_ID=
BATCH_LONG_CYCLE_SHEET_ID=
BATCH_SMALL_ENV_RANGE=A1:Z1000
BATCH_LONG_CYCLE_RANGE=A1:Z1000
QWBOT_PORT=5000
