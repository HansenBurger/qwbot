# 复制为服务器上的 .env 后填写真实值。不要提交真实 .env。
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=replace-with-your-key

BOT_TITLE=贷款核算测试日报提醒
SYSTEM_DATE_FORMAT=%Y-%m-%d
TIMEZONE=Asia/Shanghai

PROGRESS_SOURCE_URL=
BATCH_PLAN_SOURCE_URL=
PROGRESS_DOC_URL=https://doc.weixin.qq.com/sheet/your-progress-doc
BATCH_REGISTER_DOC_URL=https://doc.weixin.qq.com/sheet/your-batch-register-doc
ENVIRONMENT_STATS_DOC_URL=https://doc.weixin.qq.com/sheet/your-environment-stats-doc
AGENDA_DOC_URL=https://doc.weixin.qq.com/sheet/your-agenda-doc

# 部署到服务器时不要使用 127.0.0.1，填写服务器 IP 或域名。
FRONTEND_URL=http://your-server-ip:5000
QWBOT_PORT=5000

# docker-compose 会覆盖为 /app/data/sample_status.json。
LOCAL_STATUS_FILE=data/sample_status.json
